rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: emails
    // Fields:
    //   - uid: string
    //   - subject: string
    //   - from: string
    //   - to: string
    //   - body: string
    //   - receivedAt: timestamp
    //   - aiClassification: string (RFI, RFQ_RFP, CONTRACT_AWARD, OTHER)
    //   - aiConfidence: number
    //   - status: string (PENDING, CONFIRMED, REJECTED)
    //   - extractedData: map
    //
    // Collection: templates
    // Fields:
    //   - referenceNumber: string
    //   - templateType: string
    //   - emailId: string
    //   - data: map
    //   - status: string
    //   - assignedTo: string
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isBootstrapAdminEmail() {
      return isAuthenticated() &&
        (
          request.auth.token.email == "elvis.wiki@gmail.com" ||
          request.auth.token.email == "chiutikhong11551@gmail.com"
        );
    }

    function isAdmin() {
      return isBootstrapAdminEmail() ||
        (
          isAuthenticated() &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "boss"
        );
    }

    // Super Admin Rights
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    function isValidEmailDoc(data) {
      return data.uid is string &&
             data.subject is string &&
             data.from is string &&
             data.status in ['PENDING', 'CONFIRMED', 'REJECTED'] &&
             (!('aiClassification' in data) || data.aiClassification in ['OPPORTUNITY', 'REQUEST', 'SUBMITTED', 'AWARDED', 'OTHER']);
    }

    function isValidTemplateDoc(data) {
      return data.referenceNumber is string &&
             data.templateType in ['OPPORTUNITY', 'REQUEST', 'SUBMITTED', 'AWARDED', 'OTHER'] &&
             data.status is string;
    }

    function isValidMeetingDoc(data) {
      return data.uid is string &&
             data.title is string &&
             data.date is string &&
             data.consentLogged is bool &&
             data.redacted is bool;
    }

    function isValidTaskDoc(data) {
      return data.uid is string &&
             data.title is string &&
             data.status in ['todo', 'in_progress', 'review', 'done'] &&
             data.priority.score is int &&
             data.priority.score >= 1 && data.priority.score <= 5;
    }

    function isValidAccountDoc(data) {
      return data.name is string &&
             data.tier in ['strategic', 'priority', 'standard'] &&
             data.owner_id is string;
    }

    match /users/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin() || (
        isAuthenticated() &&
        request.auth.uid == userId &&
        (
          request.resource.data.role == resource.data.role ||
          (request.resource.data.role == "boss" && isBootstrapAdminEmail())
        )
      );
      allow delete: if isAdmin();
    }

    match /accounts/{accountId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidAccountDoc(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.owner_id);
    }

    match /emails/{emailId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidEmailDoc(request.resource.data);
      allow delete: if isAdmin();
    }

    match /templates/{templateId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidTemplateDoc(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.token.email == resource.data.assignedTo);
    }

    match /tenders/{tenderId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.token.email == resource.data.createdBy);
    }

    match /meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidMeetingDoc(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.uid);
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidTaskDoc(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && (request.auth.uid == resource.data.uid || request.auth.token.email == resource.data.assignee));
    }

    match /proposals/{proposalId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.uid);
    }

    match /replies/{replyId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }
  }
}
