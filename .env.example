# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# QWEN_API_KEY / DASHSCOPE_API_KEY: Required for Qwen API calls.
# Qwen is configured from backend environment variables only.
QWEN_API_KEY="MY_QWEN_API_KEY"

# Optional: override the Qwen compatible endpoint.
# China (Beijing): https://dashscope.aliyuncs.com/compatible-mode/v1
# International:   https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL="https://dashscope-intl.aliyuncs.com/compatible-mode/v1"

# Frontend admin overrides, comma-separated. These users are auto-promoted to boss on login.
VITE_ADMIN_EMAILS="elvis.wiki@gmail.com,chiutikhong11551@gmail.com"
